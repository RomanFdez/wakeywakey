# Copia este archivo como secrets.properties y rellena los valores.
# secrets.properties está en .gitignore — NUNCA lo subas al repo.

# Sentry — obtén el DSN en: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://xxxxx@oXXXXX.ingest.sentry.io/XXXXXXX

# PostHog — obtén la API key en: https://eu.posthog.com → Project → Settings
POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
POSTHOG_HOST=https://eu.i.posthog.com
